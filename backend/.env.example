# Required: Your Google Gemini API key
# Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...

# Server port (default: 3001)
PORT=3001

# Path to SQLite database file (default: ./data/chat.db)
DATABASE_PATH=./data/chat.db

# Max characters per user message (default: 2000)
MAX_MESSAGE_LENGTH=2000

# Max conversation turns kept in LLM context (default: 20)
MAX_HISTORY_MESSAGES=20

# Allowed frontend origin for CORS (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
